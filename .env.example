# Aegis Environment Configuration
# Copy to .env and adjust for your environment.

# --- Verifier (required for docker-compose) ---
# Dev: ephemeral keys (restart invalidates receipts)
KEY_PROVIDER=local
AEGIS_DEV_ALLOW_EPHEMERAL_KEY=1

# Production: persistent Ed25519 key (64 hex chars)
# KEY_PROVIDER=env
# AEGIS_SIGNING_KEY_HEX=<your-64-char-hex-ed25519-private-key>

# --- Proxy-Verifier Communication ---
# Use https:// when verifier TLS is enabled (mTLS)
# VERIFIER_URL=https://aegis-verifier:3000
