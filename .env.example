# Docker Compose secrets. Copy to .env and adjust for your environment.

# REQUIRED for production. Generate with: openssl rand -hex 32
# This demo value must be changed before production use.
WEBHOOK_SECRET=demo-webhook-secret-min-32-characters-long

# Grafana admin password (docker-compose). Change for production.
GRAFANA_ADMIN_PASSWORD=changeme-admin-demo-only
# GRAFANA_ADMIN_PASSWORD=<generate-with-openssl-rand-hex-16>

# Optional: Verifier API key for /v1/register, /v1/verify. When set, requires Bearer or x-api-key.
# VERIFIER_API_KEY=

# Optional: Proxy policy API key for GET/POST /policy, POST /policy/reload. When set, requires X-Catenar-Policy-Key or Bearer. Dashboard must set same value to sync policy.
# PROXY_POLICY_API_KEY=
